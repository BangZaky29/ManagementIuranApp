{
  "expo": {
    "name": "Warga Lokal",
    "slug": "ManagementIuranApp",
    "version": "1.1.6",
    "orientation": "portrait",
    "icon": "./assets/logo_warlok/warlok_1024x1024_noTransparant.png",
    "scheme": "warlok",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "notification": {
      "icon": "./assets/logo_warlok/notifikasi_icon_48x48.png",
      "color": "#0D47A1"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo_warlok/warlok_1024x1024_Transparant.png",
        "backgroundImage": "./assets/logo_warlok/white.png",
        "monochromeImage": "./assets/logo_warlok/warlok_1024x1024_Transparant.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ruangimaji29.ManagementIuranApp",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo_warlok/warlok_48x48_Transparant.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo_warlok/warlok_1024x1024_Transparant.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-media-library",
      "expo-file-system",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ea96a46-46a9-490f-b897-e82fc4af3a8a"
      }
    },
    "owner": "bangzaky0029"
  }
}